<?xml version="1.0" encoding="utf-8"?>
<!--
  Escudo Antiestafas — overlay tipo bottom-sheet sobre la app del chat (WhatsApp/SMS).

  Layout:
    - Container vertical full-screen con scrim semi-transparente arriba (oscurece el chat).
    - Card abajo con bordes superiores redondeados:
        · Pill rojo "Beto · Escudo Antiestafas"
        · Título grande
        · Texto cálido (puede mutar al recibir frase del LLM Explainer en Block 5)
        · FlexBox de chips de signals (programmatic — agregamos al render)
        · Botón verde GIGANTE "Llamar a alguien de confianza"
        · Botón gris "No responder ahora"
        · Botón texto "Ya lo sé, gracias"
-->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/scam_alert_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="bottom">

    <!-- Scrim arriba: ocupa el espacio sobre el card. Tap NO cierra (decisión de diseño:
         queremos que el adulto mayor se detenga y elija explícitamente). -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/scam_alert_scrim" />

    <LinearLayout
        android:id="@+id/scam_alert_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_scam_alert_card"
        android:elevation="16dp"
        android:padding="20dp">

        <!-- Pill de identidad: "Beto · Escudo Antiestafas" -->
        <TextView
            android:id="@+id/scam_alert_badge"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_scam_badge_pill"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:text="Beto · Escudo Antiestafas"
            android:textColor="@color/scam_alert_badge_text"
            android:textSize="13sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="14dp" />

        <TextView
            android:id="@+id/scam_alert_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ojo, esto podría ser una estafa."
            android:textColor="@color/scam_alert_title"
            android:textSize="24sp"
            android:textStyle="bold"
            android:lineSpacingExtra="2dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="8dp" />

        <TextView
            android:id="@+id/scam_alert_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Mejor frenemos un segundo antes de responder."
            android:textColor="@color/scam_alert_body"
            android:textSize="17sp"
            android:lineSpacingExtra="2dp" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="14dp" />

        <!-- Container de chips: scroll horizontal para evitar dependencias de Flexbox/Chip.
             Las chips se agregan programáticamente en ScamAlertOverlay.kt. -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="false">

            <LinearLayout
                android:id="@+id/scam_alert_signals"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <Space
            android:layout_width="match_parent"
            android:layout_height="20dp" />

        <!-- Acción primaria: llamar al contacto de confianza. Texto se completa en runtime
             ("Llamar a Mi nieto" o fallback "Llamar a alguien de confianza"). -->
        <TextView
            android:id="@+id/scam_alert_btn_call"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:background="@drawable/bg_scam_button_call"
            android:gravity="center"
            android:text="Llamar a alguien de confianza"
            android:textColor="@color/scam_alert_button_call_text"
            android:textSize="18sp"
            android:textStyle="bold"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="14dp"
            android:paddingBottom="14dp"
            android:clickable="true"
            android:focusable="true" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="10dp" />

        <TextView
            android:id="@+id/scam_alert_btn_dismiss"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:background="@drawable/bg_scam_button_dismiss"
            android:gravity="center"
            android:text="No responder ahora"
            android:textColor="@color/scam_alert_button_dismiss_text"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:clickable="true"
            android:focusable="true" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="6dp" />

        <TextView
            android:id="@+id/scam_alert_btn_acknowledge"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:gravity="center"
            android:text="Ya lo sé, gracias"
            android:textColor="@color/scam_alert_button_acknowledge_text"
            android:textSize="14sp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:clickable="true"
            android:focusable="true" />
    </LinearLayout>
</LinearLayout>
