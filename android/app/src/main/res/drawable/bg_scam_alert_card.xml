<?xml version="1.0" encoding="utf-8"?>
<!-- Card del Escudo Antiestafas: bordes superiores redondeados (estilo bottom-sheet),
     borde rojo de 2dp para reforzar la urgencia visual sin ser agresivo. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/scam_alert_surface" />
    <corners
        android:topLeftRadius="20dp"
        android:topRightRadius="20dp"
        android:bottomLeftRadius="0dp"
        android:bottomRightRadius="0dp" />
    <stroke
        android:width="2dp"
        android:color="@color/scam_alert_badge_bg" />
</shape>
